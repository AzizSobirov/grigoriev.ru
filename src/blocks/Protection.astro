  },
  {
    index: '4 / 50',
    title:
      'Отмена привлечения к субсидиарной ответственности на 311,4 млн рублей в деле о банкротстве',
    desc: 'Клиент выступал в качестве ответчика по делу о разделе совместно нажитого имущества – истец требовал разделить совместно нажитое имущество по своему усмотрению.',
    href: '#',
  },
  {
    index: '5 / 50',
    title:
      'Сохранено право собственности на долю в квартире клиента и увеличен размер денежной компенсации',
    desc: 'Клиент выступал в качестве ответчика по делу о разделе совместно нажитого имущества – истец требовал разделить совместно нажитое имущество по своему усмотрению.',
    href: '#',
  },
  {
    index: '6 / 50',
    title:
      'Сохранено право собственности на долю в квартире клиента и увеличен размер денежной компенсации',
    desc: 'Клиент выступал в качестве ответчика по делу о разделе совместно нажитого имущества – истец требовал разделить совместно нажитое имущество по своему усмотрению.',
    href: '#',
  },
  {
    index: '7 / 50',
    title:
      'Отмена привлечения к субсидиарной ответственности на 311,4 млн рублей в деле о банкротстве',
    desc: 'Клиент выступал в качестве ответчика по делу о разделе совместно нажитого имущества – истец требовал разделить совместно нажитое имущество по своему усмотрению.',
    href: '#',
  },
]
---

<!-- Protection -->
<Section name="protection">
  <div class="protection__header">
    <H2>Проверенная защита,<br />безупречная стратегия</H2>
  </div>

  <div class="protection__grid">
    {
      cases.map((item, index) => (
        <ProtectionCard
          index={item.index}
          title={item.title}
          desc={item.desc}
          href={item.href}
          class={`protection__item--${index + 1}`}
        />
      ))
    }

    <ProtectionCard
      title="Все работы"
      variant="blue"
      class="protection__item--all"
    />
  </div>
</Section>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .protection {
    padding: rem(80) 0;

    @include media('lg') {
      padding: rem(60) 0;
    }
    @include media('sm') {
      padding: rem(40) 0;
    }

    &__header {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(4, 1fr);

      .text-h2 {
        grid-column: 2 / 5;
      }

      @include media('xl') {
        grid-template-columns: 1fr;

        .text-h2 {
          grid-column: 1 / 2;
        }
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 1fr;
      gap: rem(12);

      @include media('xl') {
        grid-template-columns: repeat(3, 1fr);
        grid-auto-rows: auto;
      }
      @include media('lg') {
        grid-template-columns: repeat(2, 1fr);

        & > * {
          grid-column: span 1 !important;
          grid-row: auto !important;
        }
      }
      @include media('sm') {
        grid-template-columns: 1fr;
        gap: rem(16);
      }
    }

    // Custom spans for desktop (4 cols)
    &__item {
      &--1 {
        grid-row: 1;
        grid-column: 2 / 4;
        @include media('xl') {
          grid-row: auto;
          grid-column: 1 / 3;
        }
      }
      &--2 {
        grid-row: 2;
        grid-column: 1 / 2;
        @include media('xl') {
          grid-row: auto;
          grid-column: span 1;
        }
      }
      &--3 {
        grid-row: 2;
        grid-column: 2 / 4;
        @include media('xl') {
          grid-row: auto;
          grid-column: 1 / 4;
        }
      }
      &--4 {
        grid-row: 2;
        grid-column: 4 / 5;
        @include media('xl') {
          grid-row: auto;
          grid-column: span 1;
        }
      }
      &--5 {
        grid-row: 3;
        grid-column: 2 / 3;
        @include media('xl') {
          grid-row: auto;
          grid-column: span 2;
        }
      }
      &--6 {
        grid-row: 3;
        grid-column: 3 / 5;
        @include media('xl') {
          grid-row: auto;
          grid-column: 1 / 4;
        }
      }
      &--7 {
        grid-row: 4;
        grid-column: 2 / 4;
        @include media('xl') {
          grid-row: auto;
          grid-column: 1 / 3;
        }
      }
      &--all {
        grid-row: 4;
        grid-column: 4 / 5;
        @include media('xl') {
          grid-row: auto;
          grid-column: span 1;
        }
      }
    }
  }
</style>
