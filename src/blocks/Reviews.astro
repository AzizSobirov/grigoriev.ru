---
import { Section, H2 } from 'ui'
import { Icon } from 'astro-icon/components'

const photos = [
  {
    src: '/assets/img/reviews/1.png',
    alt: 'Клиент 1',
    name: 'Иван Иванов',
    desc: 'Успешное дело по взысканию',
  },

  {
    src: '/assets/img/reviews/2.png',
    alt: 'Клиент 2',
    name: 'Мария Сидорова',
    desc: 'Защита прав потребителей',
  },
  {
    src: '/assets/img/reviews/3.png',
    alt: 'Клиент 3',
    name: 'Анна Петрова',
    desc: 'Семейный спор',
  },
  {
    src: '/assets/img/reviews/4.png',
    alt: 'Клиент 1',
    name: 'Иван Иванов',
    desc: 'Успешное дело по взысканию',
  },
]

const reviews = [
  {
    name: 'София',
    rating: 5.0,
    text: 'Хочу поблагодарить команду Level Consulting и в особенности юриста Салавата Илдаровича за высокий профессионализм, честность и грамотную работу! Я обращалась по делу о защите прав потребителей. Меня проконсультировали, всё понятно объяснили и составили досудебную претензию...',
    source: 'Яндекс Карты',
  },
  {
    name: 'София',
    rating: 5.0,
    text: 'Хочу поблагодарить команду Level Consulting и в особенности юриста Салавата Илдаровича за высокий профессионализм, честность и грамотную работу! Я обращалась по делу о защите прав потребителей. Меня проконсультировали, всё понятно объяснили и составили досудебную претензию...',
  },
  {
    name: 'София',
    rating: 5.0,
    text: 'Хочу поблагодарить команду Level Consulting и в особенности юриста Салавата Илдаровича за высокий профессионализм, честность и грамотную работу! Я обращалась по делу о защите прав потребителей. Меня проконсультировали, всё понятно объяснили и составили досудебную претензию...',
  },
  {
    name: 'София',
    rating: 5.0,
    text: 'Хочу поблагодарить команду Level Consulting и в особенности юриста Салавата Илдаровича за высокий профессионализм, честность и грамотную работу! Я обращалась по делу о защите прав потребителей. Меня проконсультировали, всё понятно объяснили и составили досудебную претензию...',
  },
]
---

<!-- Reviews -->
<Section name="reviews">
  <div class="reviews__marquee">
    <H2 class="reviews__title">
      <span>Отзывы — Отзывы — Отзывы — Отзывы — Отзывы — Отзывы —</span>
      <span>Отзывы — Отзывы — Отзывы — Отзывы — Отзывы — Отзывы —</span>
    </H2>
  </div>

  <div class="wrapper">
    <div class="reviews__general">
      <div class="swiper">
        <div class="swiper-wrapper">
          {
            photos.map((photo) => (
              <div class="swiper-slide reviews__card">
                <div class="reviews__card-stat">
                  <div class="reviews__card-stat-info">
                    <div class="reviews__card-stat-value">500+</div>
                    <div class="reviews__card-stat-label">отзывов на 2Гис</div>
                  </div>
                  <div class="reviews__card-stat-logo">
                    <img src="/assets/img/icons/2gis.svg" alt="" />
                  </div>
                </div>
                <div class="reviews__card-img">
                  <img src={photo.src} alt={photo.alt} />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="reviews__map">
      <div class="reviews__map-info">
        <div class="reviews__map-badge">
          <img src="/assets/img/icons/marker.svg" alt="" />
        </div>

        <div class="reviews__map-logo">
          <img src="/assets/img/icons/yandex.svg" alt="" />
        </div>
      </div>

      <div class="swiper">
        <div class="swiper-wrapper">
          {
            reviews.map((review) => (
              <div class="swiper-slide">
                <div class="review-card">
                  <div class="review-card__header">
                    <div class="review-card__rating">
                      <Icon name="tabler:star-filled" />
                      <span>{review.rating.toFixed(1)}</span>
                    </div>
                    <div class="review-card__name">{review.name}</div>
                  </div>
                  <div class="review-card__text">{review.text}</div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Section>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .reviews {
    position: relative;
    padding: rem(80) 0;
    overflow: hidden;

    @include media('lg') {
      padding: rem(60) 0;
    }
    @include media('sm') {
      padding: rem(40) 0;
    }

    &::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(180deg, #a0c3d4 0%, transparent 100%);
      z-index: -1;
    }

    &__marquee {
      display: flex;
      white-space: nowrap;
    }

    &__title {
      display: inline-flex;
      animation: marquee 30s linear infinite;
      gap: rem(40);
      width: max-content;
      font-family: var(--font-secondary);
      font-weight: normal;

      span {
        display: inline-block;
      }

      @include media('sm') {
        gap: rem(20);
      }
    }

    .wrapper {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: rem(40);

      // @include media('sm') {
      //   gap: rem(20);
      // }
    }

    &__general {
      width: 100%;

      .swiper {
        height: rem(540);

        @include media('lg') {
          overflow: visible;
        }
      }

      .swiper-slide {
        height: 100%;

        @include media('sm') {
          width: rem(320);
        }
      }
    }

    &__card {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: rem(12);
      overflow: hidden;
      cursor: pointer;

      @include media('lg') {
        display: flex;
        flex-direction: column;
        gap: rem(12);
      }

      &:hover {
        .reviews__card-stat {
          opacity: 1;
        }
      }

      &-img {
        border-radius: rem(12);

        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          transition: transform 0.5s ease;
          border-radius: inherit;
        }

        @media screen and (min-width: 1025px) {
          &:hover {
            img {
              transform: scale(1.05);
            }

            .reviews__card-overlay {
              opacity: 1;
              transform: translateY(0);
            }
          }
        }
      }

      &-stat {
        position: absolute;
        inset: 0;
        background: var(--text-color);
        padding: rem(32);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        color: #fff;
        opacity: 0;
        transition: all 0.3s ease;
        z-index: 3;

        @include media('sm') {
          position: relative;
          opacity: 1;
          border-radius: rem(12);
          padding: rem(12) rem(16);
          flex-direction: row;
          align-items: center;
        }

        &-value {
          font-size: rem(40);
          font-weight: 700;
          color: #ffda3a;
          line-height: 1;
          margin-bottom: rem(8);

          @include media('sm') {
            font-size: rem(20);
            margin-bottom: 0;
          }
        }

        &-label {
          font-size: rem(16);
          opacity: 0.8;

          @include media('sm') {
            font-size: rem(12);
          }
        }

        &-logo {
          display: flex;
          align-items: center;
          gap: rem(8);

          svg {
            width: rem(32);
            height: rem(32);

            @include media('sm') {
              width: rem(24);
              height: rem(24);
            }
          }

          span {
            font-size: rem(24);
            font-weight: 700;

            @include media('sm') {
              font-size: rem(16);
            }
          }
        }
      }
    }

    &__map {
      height: rem(320);
      width: 100%;
      display: flex;
      align-items: stretch;
      gap: rem(12);

      @include media('lg') {
        flex-direction: column;
        height: auto;
      }

      &-info {
        padding: rem(24);
        width: rem(85);
        height: 100%;
        background: var(--text-color);
        border-radius: rem(12);
        flex-shrink: 0;
        display: flex;
        flex-direction: column-reverse;
        align-items: center;
        justify-content: space-between;

        @include media('lg') {
          width: 100%;
          height: auto;
          flex-direction: row;
        }
      }

      &-badge {
        width: rem(24);
        height: rem(24);

        img {
          width: 100%;
          height: 100%;
          object-fit: contain;
        }
      }

      &-logo {
        @media screen and (min-width: 1025px) {
          min-width: rem(175);
          transform: rotate(-90deg) translateX(-42%);
        }

        img {
          width: 100%;
          height: 100%;
          object-fit: contain;
        }
      }

      .swiper {
        height: 100%;
        width: 100%;
        flex-grow: 1;

        @include media('lg') {
          overflow: visible;
        }
      }

      .swiper-slide {
        @include media('sm') {
          width: rem(320);
        }
      }

      .review-card {
        background: #ffffff;
        border-radius: rem(16);
        padding: rem(24);
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);

        @include media('sm') {
          padding: rem(20);
        }

        &__header {
          margin-bottom: rem(24);
        }

        &__rating {
          display: flex;
          align-items: center;
          gap: rem(6);
          margin-bottom: rem(8);

          svg {
            width: rem(16);
            height: rem(16);
            color: var(--text-color);
          }

          span {
            font-size: rem(14);
            font-weight: 700;
          }
        }

        &__name {
          font-size: rem(24);
          font-weight: 700;

          @include media('sm') {
            font-size: rem(20);
          }
        }

        &__text {
          margin-top: auto;
          font-size: rem(16);

          @include media('sm') {
            font-size: rem(14);
          }
        }
      }
    }
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - rem(20)));
    }
  }
</style>
