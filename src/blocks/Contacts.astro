---
import { Section, H2, H3, Icon, Button } from 'ui'
---

<!-- Contacts -->
<Section name="contacts">
  <div class="contacts__wrapper">
    <div class="contacts__left">
      <H2>Контакты</H2>

      <div class="contacts__socials">
        <a href="#" class="contacts__social-item" aria-label="VK">
          <Icon src="vk.svg" />
        </a>
        <a href="#" class="contacts__social-item" aria-label="Telegram">
          <Icon src="telegram.svg" />
        </a>
        <a href="#" class="contacts__social-item" aria-label="Youtube">
          <Icon src="youtube.svg" />
        </a>
      </div>

      <div class="contacts__info">
        <a href="mailto:info@grigoriev.ru" class="contacts__info-mail"
          >info@grigoriev.ru</a
        >
        <a href="tel:+79112332222" class="contacts__info-phone"
          >+7 (911) 233-22-22</a
        >
      </div>

      <div class="contacts__address">
        <p class="contacts__address-text">
          Москва, Холодильный переулок, 3, к1с8 <br />
          2-й этаж, офис – 8210
        </p>
        <p class="contacts__address-hours">По будням с 9:00 до 20:00</p>
      </div>
    </div>

    <div class="contacts__right">
      <div class="contacts__card">
        <div class="contacts__card-header">
          <H3>Бесплатная консультация <br /> по вашим вопросам</H3>
          <img src="/assets/img/logo-white.svg" alt="" />
        </div>

        <form class="contacts__form the-form">
          <div class="contacts__form-field">
            <label>Как вас зовут?</label>
            <input type="text" name="name" placeholder="Никита" required />
          </div>
          <div class="contacts__form-field">
            <label>Номер телефона</label>
            <input
              type="tel"
              name="phone"
              placeholder="+7 (___) ___-__-__"
              required
            />
          </div>

          <div class="contacts__form-footer">
            <Button class="btn-submit">Оставить заявку</Button>

            <span class="contacts__form-separator"></span>

            <div class="contacts__form-privacy">
              <label class="checkbox">
                <input type="checkbox" required checked />
                <span class="checkmark"></span>
              </label>
              <p>
                Нажимая кнопку "Оставить заявку", вы соглашаетесь с
                <a href="#">условиями обработки персональных данных</a>.
              </p>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <Fragment slot="footer">
    <div class="contacts__map">
      <iframe
        src="https://yandex.ru/map-widget/v1/?um=constructor%3Af779e3e78e1b3e7e1f7c5e5e5e5e5e5e5e5e5e5e5e5e5e5e5e5e5e5e5e5e5e5&source=constructor"
        width="100%"
        height="100%"></iframe>
    </div>
  </Fragment>
</Section>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .contacts {
    position: relative;
    padding: rem(80) 0 0 !important;

    @include media('lg') {
      padding: rem(60) 0 0 !important;
    }
    @include media('sm') {
      padding: rem(40) 0 0 !important;
    }

    &__wrapper {
      width: 100%;
      display: flex;
      justify-content: space-between;
      gap: rem(60);

      @include media('xl') {
        gap: rem(40);
      }

      @include media('lg') {
        flex-direction: column;
      }
    }

    &__left {
      flex: 1;

      .text-h2 {
        font-size: rem(64);
        margin-bottom: rem(48);

        @include media('xl') {
          font-size: rem(48);
        }
        @include media('sm') {
          font-size: rem(36);
          margin-bottom: rem(32);
        }
      }
    }

    &__socials {
      display: flex;
      gap: rem(16);
      margin-bottom: rem(24);
    }

    &__social-item {
      --icon-size: #{rem(24)};
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.3s ease;

      &:hover {
        transform: translateY(rem(-4));
      }
    }

    &__info {
      display: flex;
      flex-direction: column;
      gap: rem(16);
      margin-bottom: rem(48);

      &-mail,
      &-phone {
        font-size: rem(20);
        font-weight: 500;
        color: var(--primary);
        text-decoration: none;
        transition: opacity 0.3s ease;

        &:hover {
          opacity: 0.7;
        }

        @include media('sm') {
          font-size: rem(18);
        }
      }
    }

    &__address {
      &-text {
        font-size: rem(24);
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: rem(12);

        @include media('sm') {
          font-size: rem(20);
        }
      }

      &-hours {
        font-size: rem(16);
        color: var(--gray);
      }
    }

    &__right {
      width: 100%;
      max-width: rem(620);

      @include media('lg') {
        max-width: 100%;
      }
    }

    &__card {
      background: #0c0c0c;
      border-radius: rem(12);
      padding: rem(32);
      color: #fff;

      @include media('sm') {
        padding: rem(20);
      }

      &-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: rem(40);
        gap: rem(15);

        @include media('sm') {
          align-items: flex-start;
          flex-direction: column-reverse;
        }

        .text-h3 {
          font-size: rem(24);
          font-weight: 700;
          line-height: 1.2;
          color: #fff;
          margin: 0;

          @include media('sm') {
            font-size: rem(20);
          }
        }

        img {
          width: rem(28);
        }
      }

      &-icon {
        flex-shrink: 0;
        margin-left: rem(20);
      }
    }

    &__form {
      display: flex;
      flex-direction: column;
      gap: rem(16);

      &-field {
        display: flex;
        flex-direction: column;
        gap: rem(8);

        label {
          font-size: rem(14);
          color: var(--gray);
        }

        input {
          width: 100%;
          height: rem(40);
          padding: 0 rem(12);
          border-radius: rem(6);
          border: none;
          background: #fff;
          color: #000;
          font-size: rem(16);

          &::placeholder {
            color: #999;
          }
        }
      }

      &-footer {
        display: flex;
        align-items: center;
        gap: rem(24);
        margin-top: rem(24);

        @include media('sm') {
          flex-direction: column-reverse;
          align-items: flex-start;
          gap: rem(16);
        }

        .btn-submit {
          width: auto;
          min-width: rem(185);
          background: #005a87;
          border-radius: 9999px;
          height: rem(46);
          flex-shrink: 0;

          @include media('sm') {
            width: 100%;
          }
        }
      }

      &-separator {
        width: 1px;
        height: rem(32);
        background: rgba(255, 255, 255, 0.1);
        flex-shrink: 0;

        @include media('sm') {
          display: none;
        }
      }

      &-privacy {
        display: flex;
        align-items: center;
        gap: rem(12);

        p {
          font-size: rem(11);
          line-height: 1.4;
          color: rgba(255, 255, 255, 0.4);

          a {
            color: #fff;
            text-decoration: underline;
            transition: color 0.3s ease;
          }
        }
      }
    }

    &__map {
      margin-top: rem(100);
      width: 100%;
      height: rem(340);
      background: #f5f5f5;

      @include media('lg') {
        margin-top: rem(40);
      }
      @include media('sm') {
        margin-top: rem(20);
        height: rem(400);
      }

      iframe {
        width: 100%;
        height: 100%;
        border: none;
      }
    }
  }

  // Custom checkbox
  .checkbox {
    display: block;
    position: relative;
    width: rem(18);
    height: rem(18);
    flex-shrink: 0;
    cursor: pointer;
    user-select: none;

    input {
      position: absolute;
      opacity: 0;
      cursor: pointer;
      height: 0;
      width: 0;
    }

    .checkmark {
      position: absolute;
      top: 0;
      left: 0;
      height: rem(18);
      width: rem(18);
      background-color: transparent;
      border: 1.5px solid #005a87;
      border-radius: rem(4);
      transition: all 0.3s ease;

      &:after {
        content: '';
        position: absolute;
        display: none;
        left: rem(6);
        top: rem(2);
        width: rem(4);
        height: rem(8);
        border: solid white;
        border-width: 0 1.5px 1.5px 0;
        transform: rotate(45deg);
      }
    }

    input:checked ~ .checkmark {
      background-color: #005a87;
      border-color: #005a87;
    }

    input:checked ~ .checkmark:after {
      display: block;
    }
  }
</style>
