const stats = [
  {
    value: '210+',
    title: 'защищенных дел',
    desc: 'Текстовое описание',
  },
  {
    value: '10+',
    title: 'направлений',
    desc: 'Текстовое описание',
  },
  {
    value: '12+',
    title: 'лет опыта работы',
    desc: 'Текстовое описание',
  },
  {
    value: '10000+',
    title: 'сбереженных клиенточасов',
    desc: 'сбереженных клиенточасов',
  },
]

const advantages = [
  {
    title: 'Каждое дело застраховано на 10 млн ₽',
    desc: 'Юридическая поддержка клиентов на любой стадии в процессе.',
  },
  {
