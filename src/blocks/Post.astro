    </div>

    <footer class="post__footer">
      <time datetime="2026-03-24">24 марта 2026</time>
    </footer>
  </article>
</Section>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .post {
    position: relative;
    padding: rem(80) 0 !important;

    @include media('lg') {
      padding: rem(60) 0 !important;
    }
    @include media('sm') {
      padding: rem(40) 0 !important;
    }

    &__container {
      max-width: rem(690);
      margin: 0 auto;
    }

    &__header {
      margin-bottom: rem(48);
      padding-bottom: rem(24);
      border-bottom: 1px solid rgba(104, 104, 104, 0.2);

      h1 {
        font-size: rem(40);
        font-weight: 700;
        line-height: 1.2;
        color: var(--text-dark, #161e28);

        @include media('sm') {
          font-size: rem(28);
        }
      }
    }

    &__content {
      // Pure HTML styles for rich text
      p {
        font-size: rem(16);
        line-height: 1.6;
        color: var(--text-dark, #161e28);
        margin-bottom: rem(24);
        opacity: 0.9;
      }

      h2 {
        font-size: rem(32);
        font-weight: 700;
        margin: rem(48) 0 rem(24);
        color: var(--text-dark, #161e28);

        @include media('sm') {
          font-size: rem(24);
        }
      }

      ul,
      ol {
        margin-bottom: rem(24);
        padding-left: rem(24);

        li {
          font-size: rem(16);
          line-height: 1.6;
          margin-bottom: rem(12);
          color: var(--text-dark, #161e28);
          opacity: 0.9;
        }
      }

      ul {
        list-style-type: disc;
      }

      ol {
        list-style-type: decimal;
      }

      img {
        max-width: 100%;
        height: auto;
        margin: rem(40) 0;
      }
    }

    &__gallery {
      margin: rem(32) 0;
      overflow: hidden;
      position: relative;

      .swiper-slide {
        height: auto;
        a {
          display: block;
          aspect-ratio: 16 / 9;
          img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            margin: 0;
            border-radius: 0;
          }
        }
      }

      .swiper-pagination {
        padding: rem(6) !important;
        left: 50%;
        transform: translateX(-50%) !important;
        width: fit-content;
        background: rgba(255, 255, 255, 0.2) !important;
        backdrop-filter: blur(10px) !important;
        border-radius: 9999px;
        bottom: rem(12);
        display: flex;
        align-items: center;
        --swiper-pagination-color: #fff;
        --swiper-pagination-bullet-inactive-color: #fff;
        --swiper-pagination-bullet-inactive-opacity: 0.4;
      }

      .swiper-button-prev,
      .swiper-button-next {
        width: rem(40);
        height: rem(40);
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: rem(8);
        color: #fff;

        &::after {
          font-size: rem(14);
        }

        &:hover {
          background: rgba(255, 255, 255, 0.4);
        }

        @include media('sm') {
          display: none;
        }
      }
    }

    &__video {
      margin: rem(32) 0;
      position: relative;
      cursor: pointer;

      &-btn {
        display: block;
        position: relative;
        overflow: hidden;

        img {
          width: 100%;
          margin: 0;
        }

        .play-btn {
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          width: rem(60);
          height: rem(60);
          background: #fff;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
          color: var(--primary, #005a87);
          box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
          transition: all 0.3s ease;

          svg {
            width: rem(32);
            height: rem(32);
          }

          @include media('sm') {
            width: rem(60);
            height: rem(60);
            svg {
              width: rem(24);
              height: rem(24);
            }
          }
        }

        &:hover {
          .play-btn {
            transform: translate(-50%, -50%) scale(1.1);
          }
        }
      }

      .caption {
        margin-top: rem(16);
        font-size: rem(14);
        color: var(--gray, #686868);
        opacity: 0.6;
      }
    }

    &__footer {
      margin-top: rem(64);
      padding-top: rem(24);
      border-top: 1px solid rgba(104, 104, 104, 0.2);
      text-align: center;

      time {
        font-size: rem(14);
        color: var(--gray, #686868);
        opacity: 0.6;
      }
    }
  }
</style>
