---
import { Image, Icon } from 'ui'
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__logo-block">
        <a href="/" class="footer__logo">
          <Image src="logo.svg" alt="logo" />
        </a>
      </div>

      <div class="footer__info">
        <div class="footer__info-item">
          <span class="footer__info-label">Москва</span>
          <p class="footer__info-text">Москва, ул. Льва Толстого, 5/1</p>
        </div>
        <div class="footer__info-item">
          <span class="footer__info-label">Время работы</span>
          <p class="footer__info-text">Ежедневно с 10:00 до 20:00</p>
        </div>
      </div>

      <div class="footer__nav">
        <ul class="footer__menu">
          <li><a href="/services">Услуги</a></li>
          <li><a href="/team">Команда</a></li>
          <li><a href="/projects">Проекты</a></li>
          <li><a href="/reviews">Отзывы</a></li>
          <li><a href="/news">Новости</a></li>
          <li><a href="/contacts">Контакты</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__main">
      <div class="footer__contacts">
        <a href="tel:+79112331212" class="footer__phone">+7 (911) 233-12-12</a>

        <div class="footer__right-side">
          <div class="footer__socials">
            <a href="#" class="footer__social-link">
              <Icon src="telegram.svg" />
              <span>Telegram</span>
            </a>
            <a href="#" class="footer__social-link">
              <Icon src="telegram.svg" />
              <span>Telegram</span>
            </a>
            <a href="#" class="footer__social-link">
              <Icon src="telegram.svg" />
              <span>Telegram</span>
            </a>
          </div>
          <a href="mailto:info@grigoriev.ru" class="footer__email"
            >info@grigoriev.ru</a
          >
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <div class="footer__bottom-links">
        <a href="/terms">Пользовательское соглашение</a>
        <a href="/privacy">Политика конфиденциальности</a>
      </div>
      <div class="footer__dev">Разработка и дизайн</div>
    </div>
  </div>

  <div class="footer__watermark">
    <!-- This would be the large justice icon -->
  </div>
</footer>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .footer {
    background: var(--text-color);
    color: #fff;
    padding-top: rem(40);
    position: relative;
    overflow: hidden;

    &__top {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: rem(40);
      margin-bottom: rem(120);

      @include media('xl') {
        grid-template-columns: 1fr 1fr;
      }

      @include media('lg') {
        grid-template-columns: 1fr;
        margin-bottom: rem(60);
      }
    }

    &__logo {
      display: block;
      width: rem(240);
      filter: brightness(0) invert(1);

      img {
        width: 100%;
        height: auto;
      }
    }

    &__info {
      display: flex;
      flex-direction: column;
      gap: rem(32);

      &-label {
        font-size: rem(14);
        color: rgba(255, 255, 255, 0.4);
        display: block;
        margin-bottom: rem(8);
      }

      &-text {
        font-size: rem(16);
        font-weight: 500;
      }
    }

    &__menu {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: rem(12) rem(40);

      @include media('sm') {
        grid-template-columns: 1fr;
      }

      a {
        font-size: rem(16);
        font-weight: 500;
        transition: opacity 0.3s;

        &:hover {
          opacity: 0.6;
        }
      }
    }

    &__main {
      margin-bottom: rem(80);
    }

    &__contacts {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: rem(40);

      @include media('xl') {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    &__phone {
      font-size: rem(100);
      font-weight: 600;
      line-height: 1;
      letter-spacing: rem(-2);

      @include media('2xl') {
        font-size: rem(80);
      }
      @include media('xl') {
        font-size: rem(72);
      }
      @include media('md') {
        font-size: rem(48);
      }
      @include media('sm') {
        font-size: rem(36);
      }
    }

    &__right-side {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: rem(24);

      @include media('xl') {
        align-items: flex-start;
        width: 100%;
      }
    }

    &__email {
      font-size: rem(80);
      font-weight: 600;
      line-height: 1;
      letter-spacing: rem(-2);

      @include media('2xl') {
        font-size: rem(64);
      }
      @include media('xl') {
        font-size: rem(56);
      }
      @include media('md') {
        font-size: rem(40);
      }
      @include media('sm') {
        font-size: rem(32);
      }
    }

    &__socials {
      display: flex;
      gap: rem(8);

      @include media('sm') {
        flex-wrap: wrap;
      }
    }

    &__social-link {
      display: flex;
      align-items: center;
      gap: rem(8);
      padding: rem(12) rem(20);
      background: rgba(255, 255, 255, 0.05);
      border-radius: rem(12);
      font-size: rem(14);
      font-weight: 500;
      transition: background 0.3s;

      &:hover {
        background: rgba(255, 255, 255, 0.1);
      }

      :global(svg) {
        width: rem(18);
        height: rem(18);
      }
    }

    &__bottom {
      padding: rem(24) 0;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      display: flex;
      justify-content: space-between;
      gap: rem(20);
      font-size: rem(14);
      color: rgba(255, 255, 255, 0.4);

      @include media('md') {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      &-links {
        display: flex;
        gap: rem(120);

        @include media('sm') {
          flex-direction: column;
          gap: rem(12);
        }

        a:hover {
          color: #fff;
        }
      }
    }

    &__watermark {
      position: absolute;
      top: rem(40);
      right: rem(-100);
      width: rem(600);
      height: rem(600);
      opacity: 0.05;
      pointer-events: none;
      background: url('/assets/img/logo.svg') no-repeat center;
      background-size: contain;
      filter: brightness(0) invert(1);

      @include media('xl') {
        display: none;
      }
    }
  }
</style>
