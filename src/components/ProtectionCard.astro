---
import { Icon } from 'astro-icon/components'

interface Props {
  index?: string
  title: string
  desc?: string
  href?: string
  variant?: 'white' | 'blue' | 'black'
  class?: string
}

const {
  index,
  title,
  desc,
  href = '#',
  variant = 'white',
  class: className,
} = Astro.props
---

<div class:list={['protection-card', `protection-card--${variant}`, className]}>
  {href && <a href={href} class="protection-card__link" />}

  <div class="protection-card__content">
    {index && <div class="protection-card__index">{index}</div>}

    <div class="protection-card__title">{title}</div>

    {desc && <div class="protection-card__desc">{desc}</div>}
  </div>

  <div class="protection-card__arrow">
    <Icon name="tabler:chevron-right" />
  </div>
</div>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .protection-card {
    position: relative;
    border-radius: rem(12);
    padding: rem(24);
    min-height: rem(360);
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    transition: all 0.3s ease;
    border: 1px solid transparent;
    overflow: hidden;

    @include media('sm') {
      padding: rem(20);
      min-height: rem(300);
    }

    &__link {
      position: absolute;
      inset: 0;
      z-index: 2;
    }

    &--white {
      background: #ffffff;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
      color: var(--text-dark, #161e28);

      .protection-card__content {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }

      .protection-card__index {
        display: inline-flex;
        padding: rem(2) rem(12);
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        font-size: rem(14);
        font-weight: 500;
        margin-bottom: rem(16);
        color: var(--text-dark, #161e28);
      }

      .protection-card__title {
        font-size: rem(24);
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: rem(12);

        @include media('sm') {
          font-size: rem(20);
        }
      }

      .protection-card__desc {
        font-size: rem(16);
        color: var(--gray, #686868);
        margin-top: auto;
      }

      .protection-card__arrow {
        position: absolute;
        bottom: rem(28);
        right: rem(28);
        color: var(--text-dark, #161e28);
        transition: transform 0.3s ease;

        @include media('sm') {
          bottom: rem(20);
          right: rem(20);
        }
      }

      &:hover {
        background-color: var(--primary, #005a87);
        color: #ffffff;
        box-shadow: 0 12px 30px rgba(0, 90, 135, 0.2);

        .protection-card__index {
          border-color: rgba(255, 255, 255, 0.3);
          color: #ffffff;
        }

        .protection-card__desc {
          color: rgba(255, 255, 255, 0.8);
        }

        .protection-card__arrow {
          color: #ffffff;
          transform: translateX(rem(5));
        }
      }
    }

    &--black {
      background: #0e0e0e;
      color: #ffffff;

      .protection-card__content {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }

      .protection-card__index {
        display: none;
      }

      .protection-card__title {
        font-size: rem(24);
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: rem(12);

        @include media('sm') {
          font-size: rem(20);
        }
      }

      .protection-card__desc {
        font-size: rem(14);
        color: rgba(255, 255, 255, 0.3);
        margin-top: auto;
        line-height: 1.4;
        max-width: 90%;
      }

      .protection-card__arrow {
        position: absolute;
        bottom: rem(28);
        right: rem(28);
        color: #ffffff;
        transition: transform 0.3s ease;

        @include media('sm') {
          bottom: rem(20);
          right: rem(20);
        }
      }

      &:hover {
        background: #1a1a1a;
        .protection-card__arrow {
          transform: translateX(rem(5));
        }
      }
    }

    &--blue {
      background-color: var(--primary, #005a87);
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      min-height: rem(200);
      padding: rem(40);
      flex-direction: column-reverse;
      gap: rem(12);

      @include media('sm') {
        min-height: unset;
        flex-direction: row;
        justify-content: space-between;
        padding: rem(16) rem(20);
        text-align: left;
        gap: rem(12);
      }

      .protection-card__content {
        display: flex;
        flex-direction: column;
        align-items: center;

        @include media('sm') {
          align-items: flex-start;
        }
      }

      .protection-card__title {
        font-size: rem(24);
        font-weight: 700;

        @include media('sm') {
          font-size: rem(16);
        }
      }

      .protection-card__arrow {
        position: static;
        margin-bottom: rem(12);
        transition: transform 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;

        @include media('sm') {
          margin-bottom: 0;
        }

        svg {
          width: rem(32);
          height: rem(32);

          @include media('sm') {
            width: rem(20);
            height: rem(20);
          }
        }
      }

      &:hover {
        background-color: var(--primary-hover, #004a6f);
        .protection-card__arrow {
          transform: scale(1.2);

          @include media('sm') {
            transform: translateX(rem(5));
          }
        }
      }
    }
  }
</style>
